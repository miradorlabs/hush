# SwiftPM build artifacts (regenerated by `swift build` / `make`)
.build/
.swiftpm/

# Package.resolved is intentionally NOT ignored — hush has no dependencies today,
# but if any are added, committing it pins exact versions for reproducible builds.

# Xcode (if you ever open the package there)
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/
DerivedData/

# Editor / OS cruft
.vscode/
.idea/
.DS_Store

# Defensive: hush is a secrets tool — never let a real .env, a sealed file, a
# decoy, or an access log get committed if you run/test hush inside this repo.
.env
.env.*
!.env.example
*.hush
access.log
